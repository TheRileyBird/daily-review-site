<style>
  .prose-legal {
    color: var(--color-neutral-400);
    line-height: 1.75;
    font-size: 0.9375rem;
  }
  .prose-legal p {
    margin-bottom: 1.25rem;
  }
  .prose-legal h2 {
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-legal ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-legal li {
    margin-bottom: 0.5rem;
  }
  .prose-legal strong {
    color: var(--color-neutral-200);
    font-weight: 600;
  }
  .prose-legal a {
    color: var(--color-gold-500);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-legal a:hover {
    color: var(--color-gold-300);
  }
</style>
