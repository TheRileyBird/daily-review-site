---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import ProblemSection from '../components/ProblemSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<PageLayout
  title="Your Daily Wisdom — Live Your Values, Every Day"
  description="The app that delivers your own hard-earned wisdom back to you everyday — in your words, in a warm human voice, before the day begins. Close the gap between knowing and living."
>
  <main>
    <Hero />
    <ProofBar />
    <ProblemSection />
    <HowItWorks />
    <Features />
    <Pricing />
    <Testimonials />
    <FinalCTA />
  </main>
</PageLayout>
