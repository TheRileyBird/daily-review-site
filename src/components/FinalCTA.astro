---
import { Image } from 'astro:assets';
import goldOwl from '../assets/images/Gold-Owl.png';
---

<section class="relative bg-neutral-900 bg-dot-grid py-28 lg:py-36 overflow-hidden" id="download">

  <!-- Ambient glow -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 flex items-center justify-center">
    <div class="w-[600px] h-[400px] rounded-full bg-gold-900/35 blur-[120px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">

    <!-- Owl logo -->
    <div class="flex justify-center mb-8">
      <Image
        src={goldOwl}
        alt="Your Daily Wisdom"
        class="h-20 w-auto drop-shadow-[0_4px_16px_rgba(197,160,89,.5)]"
        quality={90}
      />
    </div>

    <!-- Headline -->
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-6 leading-[1.06]">
      You Already Have the Wisdom.<br/>
      <span class="text-gold-500">Start Living It.</span>
    </h2>

    <p class="text-neutral-500 text-lg sm:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Download free. Write your first reminder in under two minutes.
      Tomorrow morning, hear it — before the day begins.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">

      <!-- iOS -->
      <a
        href="#"
        class="inline-flex items-center gap-3 bg-white hover:bg-neutral-100 active:scale-[.97] text-neutral-900 font-semibold px-7 py-4 rounded-2xl transition-all duration-200 shadow-[0_4px_24px_rgba(0,0,0,.3)] w-full sm:w-auto justify-center"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <p class="text-[10px] font-normal text-neutral-500 leading-none mb-0.5">Download on the</p>
          <p class="text-base font-semibold leading-none">App Store</p>
        </div>
      </a>

      <!-- Android placeholder -->
      <a
        href="#"
        class="inline-flex items-center gap-3 bg-neutral-800/80 hover:bg-neutral-800 border border-neutral-700 active:scale-[.97] text-white font-semibold px-7 py-4 rounded-2xl transition-all duration-200 w-full sm:w-auto justify-center"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 20.5v-17c0-.83 1-.98 1.44-.33l13 8.5c.38.25.38.91 0 1.16l-13 8.5C4 21.98 3 21.33 3 20.5z" opacity=".8"/>
        </svg>
        <div class="text-left">
          <p class="text-[10px] font-normal text-neutral-500 leading-none mb-0.5">Coming soon to</p>
          <p class="text-base font-semibold leading-none">Google Play</p>
        </div>
      </a>
    </div>

    <!-- Micro-copy -->
    <p class="mt-6 text-neutral-700 text-sm">
      Free forever · No credit card · Cancel premium anytime
    </p>

    <!-- Core promise -->
    <div class="mt-16 pt-12 border-t border-neutral-800 max-w-2xl mx-auto">
      <p class="text-xl sm:text-2xl text-neutral-400 leading-relaxed font-light italic">
        "You already have the wisdom to change your life.
        <span class="text-gold-500 not-italic font-medium">Your Daily Wisdom makes sure you never forget it.</span>"
      </p>
    </div>

  </div>
</section>
