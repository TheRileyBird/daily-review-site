---
// ProofBar — gold-tinted strip with key stats
---

<div class="bg-gold-50 border-y border-neutral-200 py-10">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-neutral-300/70">

      <div class="text-center px-4">
        <p style="font-family: var(--font-display);" class="text-4xl font-bold text-neutral-900 mb-1">
          4.9<span class="text-gold-550">★</span>
        </p>
        <p class="text-sm text-neutral-600 font-medium">App Store Rating</p>
      </div>

      <div class="text-center px-4">
        <p style="font-family: var(--font-display);" class="text-4xl font-bold text-neutral-900 mb-1">
          10k<span class="text-gold-550">+</span>
        </p>
        <p class="text-sm text-neutral-600 font-medium">Daily Practitioners</p>
      </div>

      <div class="text-center px-4">
        <p style="font-family: var(--font-display);" class="text-4xl font-bold text-neutral-900 mb-1">6</p>
        <p class="text-sm text-neutral-600 font-medium">Life Categories</p>
      </div>

      <div class="text-center px-4">
        <p style="font-family: var(--font-display);" class="text-4xl font-bold text-neutral-900 mb-1">
          $0
        </p>
        <p class="text-sm text-neutral-600 font-medium">To Get Started</p>
      </div>

    </div>
  </div>
</div>
