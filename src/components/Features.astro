---
// Features — gold-tinted light section, icon cards with accent border

const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>`,
    title: "Your Words Only",
    body: "Write reminders in your own language — not generic affirmations. The insight you earned is the insight that lands.",
    accent: "border-gold-550",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>`,
    title: "Automated Daily Delivery",
    body: "A single push notification every morning. Open it. Listen. Go live your day. No journaling, no effort, no willpower.",
    accent: "border-gold-550",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"/>`,
    title: "Premium Voice Readout",
    body: "Warm, human-quality audio that creates an emotionally resonant experience — not robotic text-to-speech.",
    accent: "border-gold-550",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`,
    title: "Category Organization",
    body: "Relationships. Purpose. Health. Mindset. Gratitude. Career. Organize your wisdom where it matters most.",
    accent: "border-gold-550",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>`,
    title: "Compounding Growth",
    body: "A living record of your evolution that becomes more valuable every month. Your wisdom library grows with you.",
    accent: "border-gold-550",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    title: "Free Forever Plan",
    body: "Genuine, lasting value at zero cost. No credit card required. Start practicing today and upgrade only when you're ready.",
    accent: "border-sage",
  },
];
---

<section class="bg-gold-50 bg-line-texture py-24 lg:py-32" id="features">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Label -->
    <div class="text-center mb-4">
      <span class="text-gold-550 text-xs font-bold uppercase tracking-widest">What You Get</span>
    </div>

    <!-- Heading -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <h2
        style="font-family: var(--font-display); line-height: 1.1; letter-spacing: -0.02em;"
        class="text-4xl sm:text-5xl font-bold text-neutral-900"
      >
        Everything You Need.<br/>
        <em class="not-italic text-gold-550">Nothing You Don't.</em>
      </h2>
      <p class="mt-5 text-neutral-600 text-lg leading-relaxed">
        Built around one deceptively simple idea: your wisdom, delivered consistently, changes you.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div
          x-data="{ visible: false }"
          x-intersect.once="visible = true"
          :class="visible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-6'"
          style={`transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); transition-delay: ${(i % 3) * 100}ms;`}
          class={`bg-white rounded-2xl p-7 border-l-4 ${f.accent} shadow-[0_1px_4px_rgba(18,18,18,.06),0_6px_20px_rgba(18,18,18,.04)] hover:shadow-[0_2px_8px_rgba(18,18,18,.08),0_12px_32px_rgba(18,18,18,.07)] hover:-translate-y-0.5 transition-all duration-300`}
        >
          <div class="w-11 h-11 rounded-xl bg-gold-50 border border-gold-100 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold-550" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" set:html={f.icon}/>
          </div>
          <h3 style="font-family: var(--font-display);" class="text-lg font-semibold text-neutral-900 mb-2.5">{f.title}</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
