---
// ProblemSection — "The Gap"
import Card from './Card.astro';

const problems = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>`,
    title: "The Retention Problem",
    body: "Human memory isn't designed to retain abstract insight under stress. The wisdom that feels permanent in a moment of clarity is the first thing to disappear when life gets hard.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    title: "The Consistency Problem",
    body: "Even the most motivated people struggle to maintain daily practices. Journaling, meditation, affirmations — all require active willpower. When life gets busy, these practices go first.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
    title: "The Personalization Problem",
    body: "Generic wisdom — someone else's quotes, someone else's affirmations — doesn't land the same way as insights a person has earned through their own lived experience.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>`,
    title: "The Integration Problem",
    body: "There's no existing tool that takes a person's own insights, organizes them by life category, and delivers them back at a consistent daily cadence — in a voice that feels human and alive.",
  },
];
---

<section class="bg-white py-24 lg:py-32" id="problem">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Label -->
    <div class="text-center mb-4">
      <span class="text-gold-550 text-xs font-bold uppercase tracking-widest">The Problem We Solve</span>
    </div>

    <!-- Heading -->
    <div class="max-w-3xl mx-auto text-center mb-6">
      <h2
        style="line-height: 1.1; letter-spacing: -0.02em;"
        class="text-4xl sm:text-5xl font-bold text-neutral-900"
      >
        The Gap Between<br><em class="not-italic text-gold-550">Knowing</em> and Living
      </h2>
    </div>

    <p class="text-center text-neutral-600 text-lg max-w-2xl mx-auto mb-8">
      Every year, millions invest in books, courses, therapy, and coaching — and experience genuine breakthroughs.
      Then life happens. The wisdom fades. This isn't a motivation problem.
    </p>
        <p class="text-2xl sm:text-3xl font-bold text-neutral-900 leading-snug max-w-2xl mx-auto text-center">
          It is a problem of <span class="text-gold-500">remembering</span>.
        </p>

    <!-- Problem cards -->
    <div class="grid sm:grid-cols-2 gap-5 mt-16">
      {problems.map((p, i) => (
        <Card icon={p.icon} title={p.title} body={p.body} delay={i * 100} />
      ))}
    </div>

  </div>
</section>
