---
import { Image } from 'astro:assets';
import goldOwl from '../assets/images/Gold-Owl.png';
---

<header
  x-data="{
    scrolled: false,
    open: false,
    init() {
      window.addEventListener('scroll', () => { this.scrolled = window.scrollY > 24 }, { passive: true })
    }
  }"
  :class="scrolled
    ? 'bg-[#121212]/96 shadow-[0_1px_0_rgba(255,255,255,.05)] backdrop-blur-md'
    : 'bg-transparent'"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Your Daily Wisdom">
      <Image
        src={goldOwl}
        alt="Your Daily Wisdom"
        class="h-10 scale-x-[-1] w-auto drop-shadow-[0_2px_6px_rgba(197,160,89,.45)]"
        loading="eager"
        quality={90}
      />
      <span class="text-lg font-bold tracking-tight text-white leading-none hidden sm:block">
        Your Daily Wisdom
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
      {[
        { href: '/#how-it-works', label: 'How It Works' },
        { href: '/#features',     label: 'Features' },
        { href: '/#pricing',      label: 'Pricing' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class="text-sm text-neutral-400 hover:text-white transition-colors duration-200"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right: CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <a
        href="/#download"
        class="hidden md:inline-flex items-center gap-2 bg-gold-550 hover:bg-gold-500 active:scale-[.97] text-neutral-900 font-semibold text-sm px-5 py-2.5 rounded-xl transition-all duration-200 shadow-[0_2px_12px_rgba(176,140,68,.4)]"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download Free
      </a>

      <button
        @click="open = !open"
        class="md:hidden w-9 h-9 flex items-center justify-center text-neutral-400 hover:text-white"
        :aria-expanded="open"
        aria-label="Toggle navigation"
      >
        <svg x-show="!open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
        <svg x-show="open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-3"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-3"
    class="md:hidden bg-[#1F1E1B]/98 backdrop-blur-md border-t border-neutral-700/50 px-6 pb-6 pt-3 space-y-1"
  >
    {[
      { href: '/#how-it-works', label: 'How It Works' },
      { href: '/#features',     label: 'Features' },
      { href: '/#pricing',      label: 'Pricing' },
    ].map(({ href, label }) => (
      <a
        href={href}
        @click="open=false"
        class="block text-neutral-400 hover:text-white py-3 text-sm border-b border-neutral-700/40 transition-colors"
      >
        {label}
      </a>
    ))}
    <div class="pt-4">
      <a
        href="/#download"
        @click="open=false"
        class="flex items-center justify-center gap-2 bg-gold-550 text-neutral-900 font-semibold text-sm py-3.5 rounded-xl"
      >
        Download Free
      </a>
    </div>
  </div>
</header>
