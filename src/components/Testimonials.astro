---
// Testimonials — gold-tinted bg, quote cards

const testimonials = [
  {
    stars: 5,
    quote: "I've tried journaling, meditation, every productivity app — nothing stuck. This is the first thing that actually changed how I show up for my kids every morning. The voice feels warm, not robotic. It's like having a coach who knows exactly what you need to hear.",
    name: "Michael T.",
    role: "Father of three, age 42",
  },
  {
    stars: 5,
    quote: "I'm a senior exec under constant pressure. I wrote down what I believe about leadership and how I want to treat people — and now I hear it every morning before the chaos starts. The difference in my relationships at work has been real and noticeable.",
    name: "Sarah K.",
    role: "VP of Operations",
  },
  {
    stars: 5,
    quote: "Went through a difficult divorce and was rebuilding who I wanted to be. Writing my own values into this app and hearing them read back every day was the one practice that kept me grounded. It grows with you — it's not static like a quote app.",
    name: "David R.",
    role: "Entrepreneur & father",
  },
];
---

<section class="bg-gold-50 bg-line-texture py-24 lg:py-32" id="testimonials">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Label -->
    <div class="text-center mb-4">
      <span class="text-gold-550 text-xs font-bold uppercase tracking-widest">What People Are Saying</span>
    </div>

    <!-- Heading -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <h2
        style="line-height: 1.1; letter-spacing: -0.02em;"
        class="text-4xl sm:text-5xl font-bold text-neutral-900"
      >
        Real People.<br/>
        <em class="not-italic text-gold-550">Real Change.</em>
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid md:grid-cols-3 gap-5">
      {testimonials.map((t, i) => (
        <div
          x-data="{ visible: false }"
          x-intersect.once="visible = true"
          :class="visible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-6'"
          style={`transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); transition-delay: ${i * 120}ms;`}
          class="bg-white rounded-2xl p-8 shadow-[0_1px_4px_rgba(18,18,18,.06),0_6px_20px_rgba(18,18,18,.04)] flex flex-col gap-5"
        >
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote body -->
          <p class="text-neutral-700 text-sm flex-1 -mt-2">{t.quote}</p>

          <!-- Attribution -->
          <div class="flex items-center gap-3 pt-3 border-t border-neutral-200">
            <div class="w-9 h-9 rounded-full bg-gold-100 border border-gold-300/50 flex items-center justify-center shrink-0">
              <span class="text-gold-700 text-sm font-bold">{t.initial}</span>
            </div>
            <div>
              <p class="text-neutral-900 text-sm font-semibold leading-tight">{t.name}</p>
              <p class="text-neutral-500 text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- App Store badge summary -->
    <div class="max-w-sm mx-auto mt-14 bg-white rounded-2xl p-6 text-center shadow-[0_1px_4px_rgba(18,18,18,.06)]">
      <div class="flex justify-center gap-1 mb-2">
        {Array.from({ length: 5 }).map(() => (
          <svg class="w-5 h-5 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <p class="text-3xl font-bold text-neutral-900 mb-1">4.9 / 5</p>
      <p class="text-neutral-500 text-sm">Based on 2,400+ App Store reviews</p>
    </div>

  </div>
</section>
