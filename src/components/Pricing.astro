---
// Pricing — Free + Premium with Monthly/Annual toggle

const freeFeatures = [
  "Up to 12 personal reminders",
  "3 life categories",
  "Daily push notification",
  "Voice readout (standard)",
  "Free forever",
];

const premiumFeatures = [
  "Unlimited reminders",
  "All 6 life categories",
  "Daily push notification",
  "Premium warm voice library",
  "Advanced category scheduling",
  "Priority support",
  "Cancel anytime",
];
---

<section class="bg-white py-24 lg:py-32" id="pricing" x-data="{ annual: false }">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Label -->
    <div class="text-center mb-4">
      <span class="text-gold-550 text-xs font-bold uppercase tracking-widest">Simple Pricing</span>
    </div>

    <!-- Heading -->
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h2
        style="line-height: 1.1; letter-spacing: -0.02em;"
        class="text-4xl sm:text-5xl font-bold text-neutral-900"
      >
        Start Free.<br/>
        <em class="not-italic text-gold-550">Deepen When Ready.</em>
      </h2>
      <p class="mt-5 text-neutral-600 text-lg">
        Less than a cup of coffee. More than most daily practices deliver.
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="flex items-center justify-center gap-4 mb-12">
      <span
        class="text-sm font-medium transition-colors duration-200"
        :class="!annual ? 'text-neutral-900' : 'text-neutral-400'"
      >
        Monthly
      </span>

      <!-- Toggle pill -->
      <button
        @click="annual = !annual"
        class="relative w-12 h-6 rounded-full transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-550 focus-visible:ring-offset-2"
        :class="annual ? 'bg-gold-550' : 'bg-neutral-300'"
        :aria-checked="annual"
        role="switch"
        aria-label="Toggle annual billing"
      >
        <span
          class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow-sm transition-transform duration-300"
          :class="annual ? 'translate-x-6' : 'translate-x-0'"
        ></span>
      </button>

      <span
        class="text-sm font-medium transition-colors duration-200"
        :class="annual ? 'text-neutral-900' : 'text-neutral-400'"
      >
        Annual
      </span>

      <!-- Savings badge -->
      <span
        x-show="annual"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 scale-90"
        x-transition:enter-end="opacity-100 scale-100"
        class="inline-flex items-center gap-1 bg-gold-50 border border-gold-100 text-gold-700 text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>
        </svg>
        Save 17%
      </span>
    </div>

    <!-- Cards -->
    <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-5 items-stretch">

      <!-- Free Card -->
      <div
        x-data="{ visible: false }"
        x-intersect.once="visible = true"
        :class="visible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-6'"
        class="transition-all duration-700 bg-neutral-100 border border-neutral-300 rounded-3xl p-8 h-full"
      >
        <div class="mb-6">
          <p class="text-neutral-600 text-sm font-semibold uppercase tracking-widest mb-3">Free</p>
          <div class="flex items-end gap-1.5 mb-2">
            <span class="text-5xl font-bold text-neutral-900">$0</span>
          </div>
          <p class="text-neutral-500 text-sm">Forever free — no card needed</p>
        </div>

        <a
          href="#download"
          class="block w-full text-center border-2 border-neutral-400 hover:border-gold-550 hover:bg-gold-50 text-neutral-700 hover:text-neutral-900 font-semibold py-3.5 rounded-xl transition-all duration-200 text-sm mb-7"
        >
          Download Free
        </a>

        <ul class="space-y-3">
          {freeFeatures.map(f => (
            <li class="flex items-start gap-3 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-gold-550 shrink-0 mt-[2px]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>

      <!-- Premium Card -->
      <div
        x-data="{ visible: false }"
        x-intersect.once="visible = true"
        :class="visible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-6'"
        class="transition-all duration-700 delay-100 bg-neutral-900 border border-neutral-700 rounded-3xl p-8 relative overflow-hidden shadow-[0_8px_40px_rgba(18,18,18,.25)]"
        style="transition-delay: 100ms;"
      >
        <!-- Glow -->
        <div aria-hidden="true" class="pointer-events-none absolute -top-16 -right-16 w-48 h-48 rounded-full bg-gold-900/50 blur-[60px]"></div>

        <!-- Badge — changes with toggle -->
        <div class="inline-flex items-center gap-1.5 bg-gold-550 text-neutral-900 text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span x-text="annual ? 'Best Value' : 'Most Popular'"></span>
        </div>

        <div class="mb-6">
          <p class="text-neutral-400 text-sm font-semibold uppercase tracking-widest mb-3">Premium</p>

          <!-- Monthly price -->
          <div x-show="!annual" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
            <div class="flex items-end gap-2 mb-2">
              <span class="text-5xl font-bold text-white">$4.99</span>
              <span class="text-neutral-500 text-sm mb-2">/month</span>
            </div>
            <p class="text-neutral-600 text-sm">
              <span class="text-gold-500 font-semibold">~$0.17/day</span> — less than a coffee
            </p>
          </div>

          <!-- Annual price -->
          <div x-show="annual" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
            <div class="flex items-end gap-2 mb-2">
              <span class="text-5xl font-bold text-white">$49.99</span>
              <span class="text-neutral-500 text-sm mb-2">/year</span>
            </div>
            <p class="text-neutral-600 text-sm">
              <span class="text-gold-500 font-semibold">$4.17/mo — save $9.89 vs monthly</span>
            </p>
          </div>
        </div>

        <!-- CTA — label changes with toggle -->
        <a
          href="#download"
          class="relative block w-full text-center bg-gold-550 hover:bg-gold-500 active:bg-gold-700 text-neutral-900 font-semibold py-3.5 rounded-xl transition-colors duration-200 text-sm mb-7 shadow-[0_2px_12px_rgba(176,140,68,.4)]"
        >
          <span x-text="annual ? 'Start Annual Plan' : 'Start Monthly Plan'"></span>
        </a>

        <!-- Annual savings callout -->
        <div
          x-show="annual"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="bg-gold-900/40 border border-gold-700/30 rounded-xl px-4 py-3 mb-5 text-center"
        >
          <p class="text-gold-300 text-xs font-semibold">
            Billed as one payment of $49.99 · Cancel anytime
          </p>
        </div>

        <ul class="space-y-3">
          {premiumFeatures.map(f => (
            <li class="flex items-start gap-3 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-gold-500 shrink-0 mt-[2px]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Footer note -->
    <p class="text-center text-neutral-500 text-sm mt-10">
      Cancel anytime. No hidden fees. Your wisdom library is always yours.
    </p>

  </div>
</section>
