---
import { Image } from 'astro:assets';
import screenshot from '../assets/images/screenshot.png';
---

<section class="relative min-h-screen bg-neutral-900 bg-dot-grid flex flex-col overflow-hidden">

  <!-- Ambient glows -->
  <!--<div aria-hidden="true" class="pointer-events-none absolute -top-48 -left-48 w-[500px] h-[500px] rounded-full bg-gold-900/40 blur-[140px]"></div>-->
  <!--<div aria-hidden="true" class="pointer-events-none absolute top-1/2 -right-32 w-[400px] h-[400px] rounded-full bg-gold-900/25 blur-[120px]"></div>-->

  <div class="relative flex-1 max-w-7xl mx-auto w-full px-6 pt-32 pb-16 flex flex-col lg:flex-row items-center gap-16 lg:gap-12 lg:justify-center">

    <!-- ── Left: Copy ── -->
    <div class="flex-1 text-center lg:text-left max-w-xl mx-auto lg:mx-0">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-gold-900/60 border border-gold-700/40 text-gold-300 text-[11px] font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
        <!--<span class="w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse"></span>-->
        Your Daily Practice
      </div>

      <!-- Headline -->
      <h1 class="text-[2.7rem] sm:text-[3.5rem] lg:text-[4rem] font-extrabold tracking-tight leading-[1.05] text-white mb-6">
        You Already Have<br/>
        The Wisdom To<br/>
        <span class="text-gold-500">Change Your Life</span>
      </h1>

      <!-- Sub -->
      <p class="text-neutral-500 text-lg sm:text-xl mb-10 max-w-lg mx-auto lg:mx-0">
        Your Daily Wisdom delivers your own hard-earned insights back to you every
        morning&thinsp;—&thinsp;in a warm, human voice&thinsp;—&thinsp;before the day has a chance to
        pull you away from who you're working to become.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 mb-10">
        <a
          href="#download"
          class="inline-flex items-center justify-center gap-2.5 bg-gold-550 hover:bg-gold-500 active:scale-[.97] text-neutral-900 font-semibold text-base px-8 py-4 rounded-2xl transition-all duration-200 shadow-[0_4px_24px_rgba(176,140,68,.45)] w-full sm:w-auto"
        >
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download Free on iOS
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center justify-center gap-2.5 border border-neutral-700 hover:border-neutral-500 text-neutral-300 hover:text-white font-medium text-base px-8 py-4 rounded-2xl transition-all duration-200 w-full sm:w-auto"
        >
          See How It Works
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-5 text-sm text-neutral-600">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          4.9 App Store
        </span>
        <span class="w-px h-4 bg-neutral-700"></span>
        <span>Free forever</span>
        <span class="w-px h-4 bg-neutral-700"></span>
        <span>No credit card</span>
      </div>
    </div>

    <!-- ── Right: Phone with real screenshot ── -->
    <div class="flex-shrink-0 relative w-full max-w-[260px] mx-auto lg:mx-0 xl:max-w-[280px]">
      <!--
        Phone shell: rounded-[44px] matches the corner radius of iOS devices.
        The screenshot fills the inner screen area.
      -->
      <div
        class="relative rounded-[44px] bg-neutral-900 overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,.8),0_0_0_1.5px_rgba(255,255,255,.08),inset_0_0_0_1px_rgba(255,255,255,.04)]"
        style="aspect-ratio: 1284/2778;"
      >
        <!-- Screenshot fills 100% of phone interior -->
        <Image
          src={screenshot}
          alt="Your Daily Wisdom app showing a morning wisdom reminder"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          quality={85}
        />

        <!-- Subtle screen reflection overlay -->
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: linear-gradient(135deg, rgba(255,255,255,.04) 0%, transparent 40%, transparent 60%, rgba(0,0,0,.12) 100%);"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Floating notification card — desktop only -->
      <div class="absolute -right-30 top-[38%] w-56 bg-neutral-800/90 backdrop-blur-xl border border-neutral-700/60 rounded-2xl px-4 py-3 shadow-elevated hidden xl:flex items-start gap-3 notification-pop">
        <div class="w-8 h-8 rounded-xl bg-gold-900/60 border border-gold-700/40 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/>
          </svg>
        </div>
        <div>
          <p class="text-neutral-200 text-[11px] font-semibold mb-0.5">Morning Wisdom</p>
          <p class="text-neutral-500 text-[10px]">Your daily reminder is ready. Tap to listen.</p>
        </div>
      </div>
    </div>
  </div>

<style>
  @keyframes notificationPop {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .notification-pop {
    opacity: 0;
    animation: notificationPop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 1s forwards;
  }
</style>

  <!-- Scroll cue -->
  <div class="relative flex justify-center pb-8">
    <div class="flex flex-col items-center gap-1.5 text-neutral-700">
      <span class="text-[10px] tracking-widest uppercase font-medium">Scroll</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>
